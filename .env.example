# ── Frontend (Vite) — safe to expose, prefixed VITE_ ──
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Ingestion worker (server-side ONLY — never commit real values) ──
# Supabase service-role key bypasses RLS to write match data.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# TxLINE API access (obtained via the on-chain subscription + activation flow).
TXLINE_NETWORK=mainnet             # mainnet | devnet
TXLINE_API_TOKEN=your-long-lived-api-token
# Backend Solana wallet used to subscribe to TxLINE (base58 secret key or path).
TXLINE_WALLET_SECRET=
# World Cup competition id (discover from /api/fixtures/snapshot, then pin it here).
TXLINE_WORLDCUP_COMPETITION_ID=
